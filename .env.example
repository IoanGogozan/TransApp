# Local development environment variables (safe placeholders)
# Copy this file to .env and adjust values as needed.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/transapp

PORT=3000
NODE_ENV=development
JWT_SECRET=replace_with_strong_local_secret
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_MEDIUM=
STRIPE_PRICE_PRO=

VIPPS_ENV=test
VIPPS_BASE_URL=
VIPPS_CLIENT_ID=
VIPPS_CLIENT_SECRET=
VIPPS_SUBSCRIPTION_KEY=
VIPPS_MSN=
VIPPS_SYSTEM_NAME=transapp
VIPPS_SYSTEM_VERSION=1.0.0
VIPPS_PLUGIN_NAME=transapp-backend
VIPPS_PLUGIN_VERSION=1.0.0
VIPPS_WEBHOOK_SECRET=
VIPPS_WEBHOOK_ALLOW_UNSIGNED_TEST=
VIPPS_PRICE_BASIC_ORE=
VIPPS_PRICE_MEDIUM_ORE=
VIPPS_PRICE_PRO_ORE=
PUBLIC_APP_URL=http://localhost:3000
