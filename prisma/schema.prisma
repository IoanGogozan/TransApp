// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// schema.prisma

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

/**
 * ===================== ENUMS =====================
 */

enum UserRole {
  PLATFORM_ADMIN
  ADMIN
  DRIVER
}

enum ActivityType {
  DRIVING
  OTHER_WORK
  BREAK
  AVAILABILITY
}

enum OvertimeType {
  OT_50
  OT_100
}

enum DefectStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum ChecklistAnswerValue {
  OK
  DEVIATION
  NOT_APPLICABLE
}

enum DefectSource {
  MANUAL
  CHECKLIST
}

enum DefectEventType {
  CREATED
  STATUS_CHANGED
  ASSIGNED
  UNASSIGNED
  COMMENTED
  DETAILS_UPDATED
  ATTACHMENT_ADDED
  ATTACHMENT_DELETED
  ARCHIVED
  ATTACHMENT_PURGED
}

enum Plan {
  BASIC
  MEDIUM
  PRO
}

enum Language {
  no
  en
  ro
  pl
  lt
}

enum WorkEntrySource {
  MANUAL
  TACHOGRAPH
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum WebhookProvider {
  STRIPE
  VIPPS
}

/**
 * ===================== MODELS =====================
 */

model Company {
  id              Int      @id @default(autoincrement())
  name            String
  orgNumber       String?  @map("org_number")
  slug            String   @unique
  plan            Plan     @default(BASIC)
  defaultLanguage Language @default(no) @map("default_language")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  users              User[]
  vehicles           Vehicle[]
  shifts             Shift[]
  checklistInstances ChecklistInstance[]
  defects            Defect[]
  routeOptions       RouteOption[]
  customerOptions    CustomerOption[]
  workEntries        WorkEntry[]
  vehicleCheckIns    VehicleCheckIn[]
  documents          Document[]
  passwordResetTokens PasswordResetToken[]
  subscription       Subscription?

  @@map("companies")
}

model Subscription {
  id        Int                @id @default(autoincrement())
  companyId Int                @unique @map("company_id")
  plan      Plan               @default(BASIC)
  status    SubscriptionStatus @default(TRIALING)

  stripeCustomerId     String? @map("stripe_customer_id")
  stripeSubscriptionId String? @map("stripe_subscription_id")
  vippsAgreementId     String? @map("vipps_agreement_id")
  vippsAgreementStatus String? @map("vipps_agreement_status")

  trialStart DateTime @default(now()) @map("trial_start") @db.Timestamptz
  trialEnd   DateTime @map("trial_end") @db.Timestamptz
  pastDueAt  DateTime? @map("past_due_at") @db.Timestamptz

  currentPeriodStart DateTime? @map("current_period_start") @db.Timestamptz
  currentPeriodEnd   DateTime? @map("current_period_end") @db.Timestamptz

  cancelAtPeriodEnd Boolean   @default(false) @map("cancel_at_period_end")
  canceledAt        DateTime? @map("canceled_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  company      Company       @relation(fields: [companyId], references: [id])
  vippsCharges VippsCharge[]

  @@map("subscriptions")
}

model VippsCharge {
  id             Int      @id @default(autoincrement())
  subscriptionId Int      @map("subscription_id")
  agreementId    String   @map("agreement_id")
  chargeId       String?  @map("charge_id")
  externalId     String   @map("external_id")
  dueDate        DateTime @map("due_date") @db.Timestamptz
  amount         Int      @map("amount_minor")
  currency       String   @default("NOK")
  status         String   @default("CREATED")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@unique([agreementId, externalId])
  @@index([subscriptionId])
  @@map("vipps_charges")
}

model WebhookEvent {
  id          Int             @id @default(autoincrement())
  provider    WebhookProvider
  eventId     String          @map("event_id")
  receivedAt  DateTime        @default(now()) @map("received_at") @db.Timestamptz
  processedAt DateTime?       @map("processed_at") @db.Timestamptz
  payload     Json            @map("payload")

  @@unique([provider, eventId])
  @@map("webhook_events")
}

/**
 * ------------- USERS -------------
 */

model User {
  id                 Int       @id @default(autoincrement())
  companyId          Int?      @map("company_id")
  email              String?
  phone              String?
  username           String?
  passwordHash       String    @map("password_hash")
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  tokenVersion       Int       @default(0) @map("token_version")
  role               UserRole  @default(DRIVER)
  language           Language?
  isActive           Boolean   @default(true) @map("active")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  company            Company?            @relation(fields: [companyId], references: [id])
  shifts             Shift[] // shifts assigned to the driver
  checklistInstances ChecklistInstance[]
  defectsReported    Defect[]            @relation("DefectsReportedByUser")
  defectsAssigned    Defect[]            @relation("DefectsAssignedToUser")
  defectsAdminNoteUpdated Defect[]       @relation("DefectsAdminNoteUpdatedByUser")
  defectComments     DefectComment[]     @relation("DefectCommentsUser")
  defectEvents       DefectEvent[]       @relation("DefectEventsActor")
  workEntries        WorkEntry[]
  vehicleCheckIns    VehicleCheckIn[]
  uploadedDocuments  Document[]          @relation("DocumentsUploadedByUser")
  defectAttachments  DefectAttachment[]  @relation("DefectAttachmentsUploadedByUser")
  passwordResetTokens PasswordResetToken[]

  @@unique([companyId, email])
  @@unique([companyId, phone])
  @@unique([companyId, username])
  @@index([companyId])
  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    Int      @map("user_id")
  companyId Int      @map("company_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([tokenHash])
  @@index([userId])
  @@index([companyId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

/**
 * ------------- VEHICLES -------------
 */

model Vehicle {
  id        Int      @id @default(autoincrement())
  companyId Int      @map("company_id")
  regNumber String   @map("reg_number")
  name      String
  type      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  company            Company             @relation(fields: [companyId], references: [id])
  shifts             Shift[]
  checklistInstances ChecklistInstance[]
  defects            Defect[]
  workEntries        WorkEntry[]
  checkIns           VehicleCheckIn[]

  @@unique([companyId, regNumber]) // one company cannot have two vehicles with the same registration number
  @@index([companyId])
  @@map("vehicles")
}

/**
 * ------------- SHIFTS -------------
 */

model Shift {
  id        Int       @id @default(autoincrement())
  companyId Int       @map("company_id")
  userId    Int       @map("user_id")
  vehicleId Int?      @map("vehicle_id")
  startAt   DateTime  @map("start_at") @db.Timestamptz
  endAt     DateTime? @map("end_at") @db.Timestamptz
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  company Company  @relation(fields: [companyId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([companyId, userId])
  @@index([companyId, startAt])
  @@map("shifts")
}

/**
 * ------------- CHECKLIST INSTANCES -------------
 */

model ChecklistInstance {
  id        String            @id @default(cuid())
  companyId Int               @map("company_id")
  vehicleId Int               @map("vehicle_id")
  userId    Int               @map("user_id")
  date      DateTime          @map("date") @db.Date
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  answers   ChecklistAnswer[]
  defects   Defect[]

  company Company @relation(fields: [companyId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([companyId, vehicleId, userId, date])
  @@index([companyId, date])
  @@index([companyId, vehicleId, date])
  @@map("checklist_instances")
}

/**
 * ------------- CHECKLIST ANSWERS -------------
 */

model ChecklistAnswer {
  id                  String               @id @default(cuid())
  checklistInstanceId String               @map("checklist_instance_id")
  questionKey         String               @map("question_key")
  answer              ChecklistAnswerValue
  comment             String?
  hasDeviation        Boolean              @default(false) @map("has_deviation")
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz

  checklistInstance ChecklistInstance @relation(fields: [checklistInstanceId], references: [id], onDelete: Cascade)

  @@index([checklistInstanceId])
  @@map("checklist_answers")
}

model RouteOption {
  id        String   @id @default(cuid())
  companyId Int      @map("company_id")
  name      String
  active    Boolean  @default(true)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  company     Company     @relation(fields: [companyId], references: [id])
  workEntries WorkEntry[]

  @@unique([companyId, name])
  @@index([companyId, active])
  @@map("route_options")
}

model CustomerOption {
  id        String   @id @default(cuid())
  companyId Int      @map("company_id")
  name      String
  orgNumber String?  @map("org_number")
  address   String?
  email     String?
  phone     String?
  active    Boolean  @default(true)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  company     Company     @relation(fields: [companyId], references: [id])
  workEntries WorkEntry[]

  @@unique([companyId, name])
  @@index([companyId, active])
  @@map("customer_options")
}

model WorkEntry {
  id               String          @id @default(cuid())
  companyId        Int             @map("company_id")
  userId           Int             @map("user_id")
  date             DateTime        @map("date") @db.Date
  activityType     ActivityType    @map("activity_type")
  durationMin      Int             @map("duration_min")
  customerOptionId String?         @map("customer_option_id")
  routeOptionId    String?         @map("route_option_id")
  vehicleId        Int?            @map("vehicle_id")
  note             String?
  source           WorkEntrySource @default(MANUAL)
  externalRef      String?         @map("external_ref")
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  company        Company         @relation(fields: [companyId], references: [id])
  user           User            @relation(fields: [userId], references: [id])
  customerOption CustomerOption? @relation(fields: [customerOptionId], references: [id])
  routeOption    RouteOption?    @relation(fields: [routeOptionId], references: [id])
  vehicle        Vehicle?        @relation(fields: [vehicleId], references: [id])

  @@index([companyId, userId, date])
  @@index([companyId, date])
  @@index([userId, date])
  @@index([companyId, source])
  @@map("work_entries")
}

model VehicleCheckIn {
  id        String   @id @default(cuid())
  companyId Int      @map("company_id")
  userId    Int      @map("user_id")
  vehicleId Int      @map("vehicle_id")
  allOk     Boolean  @default(true) @map("all_ok")
  note      String?
  checkedAt DateTime @default(now()) @map("checked_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([companyId, checkedAt])
  @@index([userId, checkedAt])
  @@index([companyId, vehicleId, checkedAt])
  @@map("vehicle_checkins")
}

model Document {
  id               String   @id @default(cuid())
  companyId        Int      @map("company_id")
  title            String
  mimeType         String   @map("mime_type")
  size             Int
  storagePath      String   @map("storage_path")
  uploadedByUserId Int      @map("uploaded_by_user_id")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  company    Company @relation(fields: [companyId], references: [id])
  uploadedBy User    @relation("DocumentsUploadedByUser", fields: [uploadedByUserId], references: [id])

  @@index([companyId])
  @@index([uploadedByUserId])
  @@map("documents")
}

/**
 * ------------- DEFECTS -------------
 */

model Defect {
  id                   String       @id @default(cuid())
  companyId            Int          @map("company_id")
  vehicleId            Int          @map("vehicle_id")
  reportedByUserId     Int          @map("reported_by_user_id")
  assignedToUserId     Int?         @map("assigned_to_user_id")
  checklistInstanceId  String?      @map("checklist_instance_id")
  checklistQuestionKey String?      @map("checklist_question_key")
  source               DefectSource @default(MANUAL)
  status               DefectStatus @default(OPEN)
  title                String
  description          String?
  adminNote            String?      @map("admin_note")
  adminNoteUpdatedAt   DateTime?    @map("admin_note_updated_at") @db.Timestamptz
  adminNoteUpdatedByUserId Int?     @map("admin_note_updated_by_user_id")
  createdAt            DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  resolvedAt           DateTime?    @map("resolved_at") @db.Timestamptz
  archivedAt           DateTime?    @map("archived_at") @db.Timestamptz

  company           Company            @relation(fields: [companyId], references: [id])
  vehicle           Vehicle            @relation(fields: [vehicleId], references: [id])
  reportedByUser    User               @relation("DefectsReportedByUser", fields: [reportedByUserId], references: [id])
  assignedToUser    User?              @relation("DefectsAssignedToUser", fields: [assignedToUserId], references: [id])
  adminNoteUpdatedBy User?             @relation("DefectsAdminNoteUpdatedByUser", fields: [adminNoteUpdatedByUserId], references: [id])
  checklistInstance ChecklistInstance? @relation(fields: [checklistInstanceId], references: [id])
  comments          DefectComment[]
  events            DefectEvent[]
  attachments       DefectAttachment[]

  @@unique([companyId, checklistInstanceId, checklistQuestionKey])
  @@index([companyId, status])
  @@index([companyId, vehicleId])
  @@index([companyId, createdAt])
  @@map("defects")
}

model DefectComment {
  id        String   @id @default(cuid())
  companyId Int      @map("company_id")
  defectId  String   @map("defect_id")
  userId    Int      @map("user_id")
  message   String   @map("message")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  defect Defect @relation(fields: [defectId], references: [id])
  user   User   @relation("DefectCommentsUser", fields: [userId], references: [id])

  @@index([companyId, defectId])
  @@map("defect_comments")
}

model DefectAttachment {
  id               String   @id @default(cuid())
  companyId        Int      @map("company_id")
  defectId         String   @map("defect_id")
  uploadedByUserId Int      @map("uploaded_by_user_id")
  title            String?
  mimeType         String   @map("mime_type")
  size             Int
  storagePath      String?  @map("storage_path")
  purgedAt         DateTime? @map("purged_at") @db.Timestamptz
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  defect     Defect @relation(fields: [defectId], references: [id], onDelete: Cascade)
  uploadedBy User   @relation("DefectAttachmentsUploadedByUser", fields: [uploadedByUserId], references: [id])

  @@index([companyId, defectId])
  @@index([companyId, createdAt])
  @@index([companyId, purgedAt])
  @@map("defect_attachments")
}

model DefectEvent {
  id          String          @id @default(cuid())
  companyId   Int             @map("company_id")
  defectId    String          @map("defect_id")
  type        DefectEventType @map("type")
  actorUserId Int             @map("actor_user_id")
  data        Json?           @map("data")
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz

  defect Defect @relation(fields: [defectId], references: [id])
  actor  User   @relation("DefectEventsActor", fields: [actorUserId], references: [id])

  @@index([companyId, defectId])
  @@map("defect_events")
}
