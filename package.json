{
  "name": "transapp",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.js",
  "scripts": {
    "pretest": "npm run test:db:deploy",
    "pretest:watch": "npm run test:db:deploy",
    "start": "node src/index.js",
    "dev:backend": "nodemon",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev": "concurrently -n BACKEND,FRONTEND -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "db:seed": "prisma db seed",
    "db:seed:dev": "cross-env DOTENV_CONFIG_PATH=.env prisma db seed",
    "db:seed:test": "cross-env DOTENV_CONFIG_PATH=.env.test prisma db seed",
    "test": "cross-env NODE_ENV=test DOTENV_CONFIG_PATH=.env.test vitest run",
    "test:watch": "cross-env NODE_ENV=test DOTENV_CONFIG_PATH=.env.test vitest",
    "test:db:reset": "cross-env DOTENV_CONFIG_PATH=.env.test prisma migrate reset --force",
    "test:db:deploy": "cross-env DOTENV_CONFIG_PATH=.env.test prisma migrate deploy",
    "dev:db:reset": "cross-env DOTENV_CONFIG_PATH=.env prisma migrate reset --force",
    "dev:db:deploy": "cross-env DOTENV_CONFIG_PATH=.env prisma migrate deploy",
    "build:frontend": "npm --prefix frontend run build",
    "build": "npm run build:frontend"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.11",
    "prisma": "^7.2.0",
    "supertest": "^7.1.1",
    "vitest": "^2.1.4"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "ejs": "^3.1.10",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.7",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "redis": "^4.7.1",
    "stripe": "^20.1.0",
    "zod": "^4.2.1"
  }
}
